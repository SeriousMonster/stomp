    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "app-store-connect",
    "app-store-connect-api",
    "appstoreconnect",
    "apple",
    "apple-developer",
    "app-store",
    "ios",
    "macos",
    "testflight",
    "in-app-purchase",
    "subscriptions",
    "xcode-cloud",
    "game-center",
    "claude",
    "cursor",
    "ai",
    "stomp"
  ],
  "author": "seriousmonster",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SeriousMonster/stomp.git"
  },
  "homepage": "https://github.com/SeriousMonster/stomp",
  "bugs": {
    "url": "https://github.com/SeriousMonster/stomp/issues"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
